# Vercel: Copy to .env.vercel, fill values, paste in Settings → Environment Variables → Bulk Add
# 1. Run: php artisan key:generate --show  (copy output to APP_KEY)
# 2. Replace APP_URL with your Vercel domain (e.g. https://portfolio-xxx.vercel.app)
# 3. Fill EmailJS values from your local .env

APP_NAME=Laravel
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:Y5Q3oGJ3GrBDJ8OvyGZ9rl+16ekgJmarh8W4vp4mA1w=
APP_URL=https://portfolio-one-rosy-zosd3jew2b.vercel.app
APP_TIMEZONE=UTC
APP_LOCALE=en
APP_MAINTENANCE_DRIVER=file

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
CACHE_STORE=array
QUEUE_CONNECTION=sync
LOG_CHANNEL=stderr

APP_CONFIG_CACHE=/tmp/config.php
APP_EVENTS_CACHE=/tmp/events.php
APP_PACKAGES_CACHE=/tmp/packages.php
APP_ROUTES_CACHE=/tmp/routes.php
APP_SERVICES_CACHE=/tmp/services.php
VIEW_COMPILED_PATH=/tmp

