# Vercel Environment Variables
# Copy this file to .env.vercel and fill values from your local .env
# Then: Vercel Dashboard → Project → Settings → Environment Variables → Bulk Add (paste contents)

APP_NAME=Laravel
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-app.vercel.app
APP_KEY=base64:your-app-key-here

# Required for EmailJS contact form
EMAILJS_PUBLIC_KEY=
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=template_gxpo1p5
EMAILJS_AUTOREPLY_TEMPLATE_ID=template_qwqoxq7

# Vercel serverless paths
APP_CONFIG_CACHE=/tmp/config.php
APP_EVENTS_CACHE=/tmp/events.php
APP_PACKAGES_CACHE=/tmp/packages.php
APP_ROUTES_CACHE=/tmp/routes.php
APP_SERVICES_CACHE=/tmp/services.php
VIEW_COMPILED_PATH=/tmp
LOG_CHANNEL=stderr
SESSION_DRIVER=cookie
CACHE_STORE=array
